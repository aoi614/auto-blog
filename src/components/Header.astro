---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header id="site-header">
	<nav>
		<a href={import.meta.env.BASE_URL} class="logo">
			<span class="logo-icon">📡</span>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">ホーム</HeaderLink>
			<HeaderLink href="/blog">ブログ</HeaderLink>
			<HeaderLink href="/about">サイトについて</HeaderLink>
		</div>
		<div class="nav-actions">
			<a href="/rss.xml" target="_blank" aria-label="RSSフィード" class="rss-link">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2zm1.5 12a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm4.5-.5a5.5 5.5 0 0 0-5.5-5.5.5.5 0 0 1 0-1 6.5 6.5 0 0 1 6.5 6.5.5.5 0 0 1-1 0zm4 0a9.5 9.5 0 0 0-9.5-9.5.5.5 0 0 1 0-1 10.5 10.5 0 0 1 10.5 10.5.5.5 0 0 1-1 0z"
					></path></svg
				>
			</a>
			<button class="mobile-toggle" id="mobile-toggle" aria-label="メニューを開く">
				<span></span>
				<span></span>
				<span></span>
			</button>
		</div>
	</nav>
</header>

<!-- Mobile overlay -->
<div class="mobile-overlay" id="mobile-overlay">
	<div class="mobile-menu">
		<a href="/" class="mobile-link">ホーム</a>
		<a href="/blog" class="mobile-link">ブログ</a>
		<a href="/about" class="mobile-link">サイトについて</a>
		<a href="/rss.xml" target="_blank" class="mobile-link">RSS</a>
	</div>
</div>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: linear-gradient(135deg, var(--dark-bg) 0%, var(--dark-bg-mid) 100%);
		border-bottom: 1px solid var(--dark-border);
		backdrop-filter: blur(12px);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 64px;
	}

	/* Logo */
	.logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--dark-text);
		font-weight: 700;
		font-size: 1.1rem;
		transition: opacity 0.2s;
	}
	.logo:hover {
		opacity: 0.85;
		color: var(--dark-text);
	}
	.logo-icon {
		font-size: 1.3rem;
	}
	.logo-text {
		background: linear-gradient(90deg, #f1f5f9, #38bdf8);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	/* Nav Links */
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	.nav-links :global(a) {
		padding: 0.5em 0.9em;
		color: var(--dark-text-muted);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		border-radius: 8px;
		transition: color 0.2s, background 0.2s;
		border-bottom: none;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--dark-text);
		background: rgba(255, 255, 255, 0.06);
	}
	.nav-links :global(a.active) {
		color: var(--accent-light);
		font-weight: 600;
		text-decoration: none;
	}

	/* Actions */
	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.rss-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 8px;
		color: var(--dark-text-muted);
		transition: color 0.2s, background 0.2s;
	}
	.rss-link:hover {
		color: var(--accent-light);
		background: rgba(255, 255, 255, 0.06);
	}

	/* Mobile Toggle */
	.mobile-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 4px;
		width: 36px;
		height: 36px;
		border-radius: 8px;
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 8px;
	}
	.mobile-toggle span {
		display: block;
		width: 100%;
		height: 2px;
		background: var(--dark-text-muted);
		border-radius: 2px;
		transition: transform 0.3s, opacity 0.3s;
	}

	/* Mobile Overlay */
	.mobile-overlay {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 99;
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: blur(4px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s;
	}
	.mobile-overlay.open {
		opacity: 1;
		pointer-events: auto;
	}
	.mobile-menu {
		position: absolute;
		top: 64px;
		left: 0;
		right: 0;
		background: var(--dark-bg-mid);
		border-bottom: 1px solid var(--dark-border);
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		transform: translateY(-10px);
		opacity: 0;
		transition: transform 0.3s, opacity 0.3s;
	}
	.mobile-overlay.open .mobile-menu {
		transform: translateY(0);
		opacity: 1;
	}
	.mobile-link {
		display: block;
		padding: 0.8em 1em;
		color: var(--dark-text-muted);
		text-decoration: none;
		font-size: 1rem;
		font-weight: 500;
		border-radius: 8px;
		transition: color 0.2s, background 0.2s;
	}
	.mobile-link:hover {
		color: var(--dark-text);
		background: rgba(255, 255, 255, 0.06);
	}

	@media (max-width: 720px) {
		.nav-links {
			display: none;
		}
		.mobile-toggle {
			display: flex;
		}
		.mobile-overlay {
			display: block;
		}
	}
</style>

<script>
	const toggle = document.getElementById('mobile-toggle');
	const overlay = document.getElementById('mobile-overlay');

	toggle?.addEventListener('click', () => {
		overlay?.classList.toggle('open');
		const isOpen = overlay?.classList.contains('open');
		toggle.setAttribute('aria-label', isOpen ? 'メニューを閉じる' : 'メニューを開く');
	});

	overlay?.addEventListener('click', (e) => {
		if (e.target === overlay) {
			overlay.classList.remove('open');
			toggle?.setAttribute('aria-label', 'メニューを開く');
		}
	});
</script>
