---
/**
 * AdSense ad unit component.
 * Inserts a responsive display ad unit.
 * Props:
 *   slot: string — ad slot ID (optional, defaults to auto format)
 *   format: string — auto | rectangle | horizontal (optional)
 *   className: string — additional CSS class (optional)
 */
interface Props {
	slot?: string;
	format?: 'auto' | 'rectangle' | 'horizontal';
	className?: string;
}

const { format = 'auto', className = '' } = Astro.props;
---

<div class={`ad-container ${className}`}>
	<p class="ad-label">広告</p>
	<ins class="adsbygoogle"
		style="display:block"
		data-ad-client="ca-pub-8204767432830277"
		data-ad-format={format === 'auto' ? 'auto' : format === 'rectangle' ? 'rectangle' : 'horizontal'}
		data-full-width-responsive="true">
	</ins>
</div>

<style>
	.ad-container {
		margin: 2rem 0;
		text-align: center;
	}
	.ad-label {
		font-size: 0.7rem;
		color: rgb(var(--gray));
		margin: 0 0 0.3rem;
		text-align: center;
		letter-spacing: 0.1em;
	}
</style>

<script is:inline>
	(adsbygoogle = window.adsbygoogle || []).push({});
</script>
