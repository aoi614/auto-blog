---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	pubDate?: Date;
	updatedDate?: Date;
	type?: 'website' | 'article';
	breadcrumbs?: { name: string; url: string }[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image = FallbackImage,
	pubDate,
	updatedDate,
	type = 'website',
	breadcrumbs,
} = Astro.props;

// Build structured data
const structuredData: Record<string, any> = {
	"@context": "https://schema.org",
	"@type": type === 'article' ? "BlogPosting" : "WebSite",
	"headline": title,
	"description": description,
	"image": new URL(typeof image === 'string' ? image : image.src, Astro.url).toString(),
	"url": canonicalURL.toString(),
	"author": {
		"@type": "Organization",
		"name": "AIトレンド速報",
		"url": Astro.site?.toString() || "https://ai-trend-news.com"
	},
	"publisher": {
		"@type": "Organization",
		"name": "AIトレンド速報",
		"url": Astro.site?.toString() || "https://ai-trend-news.com",
		"logo": {
			"@type": "ImageObject",
			"url": new URL("/favicon.svg", Astro.site || "https://ai-trend-news.com").toString()
		}
	}
};

if (pubDate) {
	structuredData.datePublished = pubDate.toISOString();
}
if (updatedDate) {
	structuredData.dateModified = updatedDate.toISOString();
} else if (pubDate) {
	structuredData.dateModified = pubDate.toISOString();
}

// Breadcrumb structured data
const breadcrumbData = breadcrumbs ? {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": breadcrumbs.map((item, index) => ({
		"@type": "ListItem",
		"position": index + 1,
		"name": item.name,
		"item": new URL(item.url, Astro.site || "https://ai-trend-news.com").toString()
	}))
} : null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<ClientRouter fallback="swap" />

<!-- PWA / Web App Settings -->
<link rel="manifest" href="/manifest.json" />
<meta name="theme-color" content="#0f172a" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />

<!-- Google Fonts: Noto Sans JP -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(typeof image === 'string' ? image : image.src, Astro.url)} />
<meta property="og:site_name" content="AIトレンド速報" />
<meta property="og:locale" content="ja_JP" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(typeof image === 'string' ? image : image.src, Astro.url)} />

<!-- Article-specific meta -->
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- SEO JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

<!-- Breadcrumb JSON-LD -->
{breadcrumbData && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />}

<!-- Google tag (gtag.js) -->
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-L0YV5M9E9L"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-L0YV5M9E9L');
</script>

<!-- Google AdSense -->
<script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8204767432830277" crossorigin="anonymous"></script>

<!-- Initialize Theme -->
<script is:inline>
	const setDarkMode = () => {
		const theme = (() => {
			if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
				return localStorage.getItem('theme');
			}
			return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
		})();
		const isDark = theme === 'dark';
		document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
		document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
	};
	setDarkMode();
	document.addEventListener('astro:after-swap', setDarkMode);
</script>

<!-- PWA Service Worker Registration -->
<script is:inline>
	if ('serviceWorker' in navigator) {
		window.addEventListener('load', () => {
			navigator.serviceWorker.register('/sw.js').catch((error) => {
				console.error('ServiceWorker registration failed: ', error);
			});
		});
	}
</script>
