---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`ブログ一覧 | ${SITE_TITLE}`} description="AIトレンド速報の全記事一覧です。最新のAIニュースやツール情報をまとめてお届けします。" />
		<style>
			/* ===== Blog Grid ===== */
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-card {
				background: var(--card-bg);
				border-radius: var(--card-radius);
				overflow: hidden;
				box-shadow: var(--card-shadow);
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			.post-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--card-shadow-hover);
			}
			.post-card a {
				text-decoration: none;
				display: block;
			}
			.post-card img {
				width: 100%;
				aspect-ratio: 1200 / 630;
				object-fit: cover;
				border-radius: 0;
				margin: 0;
			}
			.post-card-body {
				padding: 1.2rem 1.5rem 1.5rem;
			}
			.post-card-body .date {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				margin-bottom: 0.5rem;
			}
			.post-card-body h3 {
				font-size: 1.05rem;
				font-weight: 600;
				line-height: 1.5;
				color: rgb(var(--gray-dark));
				margin: 0;
				transition: color 0.2s;
			}
			.post-card a:hover h3 {
				color: var(--accent);
			}
			.posts-count {
				text-align: center;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				margin-top: 2rem;
			}

			@media (max-width: 720px) {
				.posts-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />

		<!-- Mini Hero -->
		<section class="mini-hero">
			<h1>📰 すべての記事</h1>
			<p>{posts.length}件の記事を公開中</p>
			<div class="gradient-bar"></div>
		</section>

		<!-- Posts Grid -->
		<div class="content-container">
			<ul class="posts-grid">
				{posts.map((post) => (
					<li class="post-card">
						<a href={`/blog/${post.id}/`}>
							{post.data.heroImage && (
								<Image width={600} height={315} src={post.data.heroImage} alt={post.data.title} />
							)}
							<div class="post-card-body">
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3>{post.data.title}</h3>
							</div>
						</a>
					</li>
				))}
			</ul>
		</div>

		<Footer />
	</body>
</html>
