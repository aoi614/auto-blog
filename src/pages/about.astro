---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`このサイトについて | ${SITE_TITLE}`} description="AIトレンド速報は、AIが毎日自動で最新ニュースをリサーチ・執筆・公開する「無人メディア運営」の実験プロジェクトです。" />
		<style>
			/* ===== Header ===== */
			.about-header {
				background: linear-gradient(135deg, #0c1222 0%, #0f172a 40%, #1e293b 100%);
				padding: 4rem 2rem 3rem;
				text-align: center;
				position: relative;
				overflow: hidden;
			}
			.about-header::before {
				content: '';
				position: absolute;
				top: -100px;
				left: -60px;
				width: 350px;
				height: 350px;
				border-radius: 50%;
				background: radial-gradient(circle, rgba(14,165,233,0.15) 0%, transparent 70%);
				pointer-events: none;
			}
			.about-header::after {
				content: '';
				position: absolute;
				bottom: -80px;
				right: -40px;
				width: 300px;
				height: 300px;
				border-radius: 50%;
				background: radial-gradient(circle, rgba(56,189,248,0.1) 0%, transparent 70%);
				pointer-events: none;
			}
			.about-header h1 {
				font-size: 2.2rem;
				font-weight: 700;
				color: #f1f5f9;
				margin: 0 0 0.8rem;
				position: relative;
				z-index: 1;
			}
			.about-header p {
				color: #94a3b8;
				font-size: 1rem;
				line-height: 1.7;
				max-width: 560px;
				margin: 0 auto;
				position: relative;
				z-index: 1;
			}
			.about-header .accent-bar {
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				height: 4px;
				background: linear-gradient(90deg, #0ea5e9, #38bdf8, #0ea5e9);
			}

			/* ===== Content ===== */
			.about-content {
				max-width: 780px;
				margin: 0 auto;
				padding: 3rem 1.5rem 4rem;
			}

			/* ===== Feature Cards ===== */
			.about-cards {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.2rem;
				margin: -2rem 0 3rem;
				position: relative;
				z-index: 2;
				max-width: 780px;
				margin-left: auto;
				margin-right: auto;
				padding: 0 1.5rem;
				margin-top: -2rem;
			}
			.about-card {
				background: white;
				border-radius: 16px;
				padding: 1.5rem;
				text-align: center;
				box-shadow: 0 4px 20px rgba(0,0,0,0.08);
				transition: transform 0.3s ease;
			}
			.about-card:hover {
				transform: translateY(-4px);
			}
			.about-card .icon {
				font-size: 2rem;
				margin-bottom: 0.6rem;
			}
			.about-card h3 {
				font-size: 0.95rem;
				font-weight: 600;
				margin: 0 0 0.4rem;
				color: rgb(var(--gray-dark));
			}
			.about-card p {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				line-height: 1.6;
				margin: 0;
			}

			/* ===== Sections ===== */
			.section {
				margin-bottom: 2.5rem;
			}
			.section h2 {
				font-size: 1.4rem;
				font-weight: 700;
				color: rgb(var(--gray-dark));
				margin: 0 0 1rem;
				padding-bottom: 0.6rem;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			.section p {
				font-size: 1rem;
				color: rgb(var(--gray-dark));
				line-height: 1.85;
			}

			/* ===== Tech Stack ===== */
			.tech-stack {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				margin-top: 1rem;
			}
			.tech-tag {
				display: inline-block;
				background: rgba(14, 165, 233, 0.08);
				border: 1px solid rgba(14, 165, 233, 0.2);
				color: var(--accent-dark);
				padding: 0.3em 0.9em;
				border-radius: 999px;
				font-size: 0.8rem;
				font-weight: 500;
			}

			/* ===== Info Box ===== */
			.info-box {
				background: linear-gradient(135deg, rgba(14,165,233,0.06) 0%, rgba(56,189,248,0.04) 100%);
				border: 1px solid rgba(14,165,233,0.15);
				border-radius: 16px;
				padding: 1.5rem 2rem;
				margin-top: 1rem;
			}
			.info-box p {
				margin: 0;
				font-size: 0.95rem;
			}

			/* ===== Content List ===== */
			.content-list {
				list-style: none;
				padding: 0;
				margin: 1rem 0 0;
			}
			.content-list li {
				display: flex;
				align-items: flex-start;
				gap: 0.8rem;
				padding: 0.8rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.content-list li:last-child {
				border-bottom: none;
			}
			.content-list .list-icon {
				font-size: 1.3rem;
				flex-shrink: 0;
				margin-top: 0.1rem;
			}
			.content-list .list-text strong {
				display: block;
				font-size: 0.95rem;
				color: rgb(var(--gray-dark));
				margin-bottom: 0.2rem;
			}
			.content-list .list-text span {
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}

			/* ===== CTA ===== */
			.cta-section {
				text-align: center;
				padding: 2rem;
				background: white;
				border-radius: 20px;
				box-shadow: 0 4px 24px rgba(0,0,0,0.06);
			}
			.cta-section h2 {
				border: none;
				text-align: center;
				padding-bottom: 0;
			}
			.cta-section p {
				color: rgb(var(--gray));
				margin-bottom: 1.5rem;
			}
			.cta-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				padding: 0.8em 2em;
				border-radius: 12px;
				background: linear-gradient(135deg, #0ea5e9, #0284c7);
				color: white;
				font-weight: 600;
				font-size: 1rem;
				text-decoration: none;
				transition: all 0.3s ease;
				box-shadow: 0 4px 20px rgba(14, 165, 233, 0.3);
			}
			.cta-btn:hover {
				transform: translateY(-2px);
				box-shadow: 0 8px 30px rgba(14, 165, 233, 0.4);
				color: white;
			}

			/* ===== Responsive ===== */
			@media (max-width: 768px) {
				.about-header {
					padding: 3rem 1.5rem 2.5rem;
				}
				.about-header h1 {
					font-size: 1.6rem;
				}
				.about-cards {
					grid-template-columns: 1fr;
					gap: 0.8rem;
				}
				.about-content {
					padding: 2rem 1rem 3rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />

		<!-- Header -->
		<section class="about-header">
			<h1>🤖 このサイトについて</h1>
			<p>AIトレンド速報の仕組みと、私たちが目指すもの</p>
			<div class="accent-bar"></div>
		</section>

		<!-- Feature Cards -->
		<div class="about-cards">
			<div class="about-card">
				<div class="icon">🤖</div>
				<h3>完全自動運営</h3>
				<p>記事の執筆から公開まで、すべてAIが自動で行います</p>
			</div>
			<div class="about-card">
				<div class="icon">📡</div>
				<h3>毎日更新</h3>
				<p>最新のAIニュースをGoogle Newsから自動収集</p>
			</div>
			<div class="about-card">
				<div class="icon">⚡</div>
				<h3>実験プロジェクト</h3>
				<p>AIでどこまでメディアが作れるか挑戦中</p>
			</div>
		</div>

		<div class="about-content">
			<!-- What is this site -->
			<section class="section">
				<h2>AIトレンド速報とは</h2>
				<p>
					<strong>「AIトレンド速報」</strong>は、日々めまぐるしく進化するAIの世界を追いかけて、
					最新ニュースをわかりやすくまとめているブログです。
				</p>
				<div class="info-box">
					<p>
						💡 実はこのサイトの記事、LLM（大規模言語モデル）を使ったスクリプトで
						<strong>毎日自動でリサーチ・執筆・公開</strong>しています。
						運営者が手動で記事を書くことはなく、AIが最新ニュースをピックアップして
						記事にまとめるという「無人メディア運営」の実験プロジェクトです。
					</p>
				</div>
			</section>

			<!-- Content Types -->
			<section class="section">
				<h2>こんな記事を書いています</h2>
				<ul class="content-list">
					<li>
						<span class="list-icon">🔧</span>
						<div class="list-text">
							<strong>AIツールの最新情報</strong>
							<span>話題の生成AIや便利ツールの使い方をわかりやすく紹介</span>
						</div>
					</li>
					<li>
						<span class="list-icon">📰</span>
						<div class="list-text">
							<strong>業界ニュース</strong>
							<span>OpenAI、Google、Anthropicなどの最新動向をキャッチアップ</span>
						</div>
					</li>
					<li>
						<span class="list-icon">💬</span>
						<div class="list-text">
							<strong>プロンプトのコツ</strong>
							<span>AIからより良い回答を引き出すテクニックを解説</span>
						</div>
					</li>
				</ul>
			</section>

			<!-- Tech Stack -->
			<section class="section">
				<h2>使用技術</h2>
				<p>このサイトは以下のテクノロジーで構築・運用されています。</p>
				<div class="tech-stack">
					<span class="tech-tag">Astro</span>
					<span class="tech-tag">TypeScript</span>
					<span class="tech-tag">Gemini API</span>
					<span class="tech-tag">GitHub Actions</span>
					<span class="tech-tag">GitHub Pages</span>
					<span class="tech-tag">Google News RSS</span>
					<span class="tech-tag">satori + sharp</span>
				</div>
			</section>

			<!-- CTA -->
			<section class="section cta-section">
				<h2>最新のAIニュースをチェック</h2>
				<p>「AIでここまでできるのか！」と思ってもらえたら嬉しいです。</p>
				<a href="/blog" class="cta-btn">
					記事を読む →
				</a>
			</section>
		</div>

		<Footer />
	</body>
</html>
